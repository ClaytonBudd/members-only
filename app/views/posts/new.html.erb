<h1>Posts#new</h1>


<%= form_with model: @post do |form| %>
  <%if @post.errors.any?%>
    <ul>
      <% @post.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <%end%>
    </ul>
  <%end%>  
  <div>
    <%= form.label :title %>
    <%= form.text_field :title %>
  </div>
  <div>
    <%= form.label :body %>
    <%= form.text_field :body %>
  </div>
  <%=form.submit %>
<%end%>

<%= current_user.id %>